# AgentPass Demo — environment variables
# Copy to .env and adjust if needed (defaults work out-of-the-box)

# Canonical HTTPS URL embedded in JWT aud claim.
# TokenRequest requires https:// — the local demo transport uses plain HTTP.
# Must match in both merchant_api.py and agent_client.py.
MERCHANT_AUD=https://agentpass-demo.local/v1/pay

# Merchant server bind address (inside container or local)
MERCHANT_HOST=0.0.0.0
MERCHANT_PORT=8000

# Shared keypair file (generated by merchant on first startup, gitignored)
KEYS_FILE=examples/keys/demo_keys.json
